
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    //need to active this 3 to check types
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": "../",         // 根目录作为 baseUrl
    "paths": {
      "@shared/*": ["shared/*"]  // 给 shared 目录一个别名
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}