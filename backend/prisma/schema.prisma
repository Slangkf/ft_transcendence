datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model User {
    id          Int         @id @default(autoincrement())
    createdAt   DateTime    @default(now())
    email       String      @unique @db.VarChar(255)
    username    String      @unique @db.VarChar(255)
    password    String      @db.VarChar(255)
    url         String?     @db.VarChar(512)
    score       Int?        @default(0)
    wins        Int?        @default(0)
    played      Int?        @default(0)
    friendsNb   Int?        @default(0)
    status      UserStatus  @default(OFFLINE)
    role        Role        @default(USER)
    quizzes     Quiz[]

    sentFriendships     Friendship[] @relation("SentFriendships")
    receivedFriendships Friendship[] @relation("ReceivedFriendships")
    
    playerMatches      PlayerMatch[]
    matchesWon         MatchResult[] @relation("MatchWinner")

    sentMessages        Message[] @relation("SentMessages")
    receivedMessages    Message[] @relation("ReceivedMessages")
}

model Quiz {
  id          Int        @id @default(autoincrement())
  title       String
  category    String
  questions   Question[]
  
  author      User       @relation(fields: [authorId], references: [id])
  authorId    Int

  matchResults  MatchResult[]
}

model Question {
  id          Int      @id @default(autoincrement())
  text        String
  options     String[]
  answer      String
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  quizId      Int
}

model Friendship {
  id        Int              @id @default(autoincrement())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  userId    Int
  friendId  Int
  
  status    FriendshipStatus @default(PENDING)
  
  user   User @relation("SentFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("ReceivedFriendships", fields: [friendId], references: [id], onDelete: Cascade)
  
  @@unique([userId, friendId])
}

model Message {
    id          Int         @id @default(autoincrement())
    createdAt   DateTime    @default(now())

    senderId    Int         
    receiverId  Int
    content     String      @db.VarChar(2000)
    read        Boolean     @default(false)

    sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
    receiver    User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
    
    @@index([senderId, receiverId])
    @@index([receiverId, senderId])
}

model MatchResult {
    id        Int          @id @default(autoincrement())
    createdAt DateTime     @default(now())
    
    players   PlayerMatch[]
    
    winnerId  Int?
    winner    User?        @relation("MatchWinner", fields: [winnerId], references: [id])
    
    mode       GameMode
    quizId     Int?
    quiz       Quiz?    @relation(fields: [quizId], references: [id])
        
    @@index([winnerId])
    @@index([mode])
}

model PlayerMatch {
    id        Int         @id @default(autoincrement())
    userId    Int
    matchId   Int
    score     Int   @default(0)
    correctAnswers  Int     @default(0)
    rank        Int     @default(0)
    
    user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    match     MatchResult @relation(fields: [matchId], references: [id], onDelete: Cascade)
    
    @@unique([userId, matchId])
    @@index([userId])
    @@index([matchId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum Role {
    USER
    ADMIN
}

enum UserStatus {
    ONLINE
    OFFLINE
}

enum    GameMode {
    SOLO
    AI
    MULTIPLAYER
    TOURNAMENT
}
