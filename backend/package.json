{
  "name": "backend",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node index.js",
    "dev": "nodemon --exec ts-node index.ts",
    "db:migrate": "prisma db push --schema=./database/schema.prisma",
    "db:seed": "ts-node database/seed.ts",
    "db:studio": "prisma studio --schema=./database/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}