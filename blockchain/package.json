{
  "name": "transcendence-blockchain",
  "version": "1.0.0",
  "description": "Solidity smart contract storing ft_transcendence tournament scores on Avalanche (Fuji testnet).",
  "scripts": {
    "compile": "hardhat compile",
    "test": "TS_NODE_TRANSPILE_ONLY=1 hardhat test",
    "node": "hardhat node",
    "deploy:fuji": "TS_NODE_TRANSPILE_ONLY=1 hardhat run scripts/deploy.ts --network fuji",
    "deploy:localhost": "TS_NODE_TRANSPILE_ONLY=1 hardhat run scripts/deploy.ts --network localhost"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0"
  }
}
