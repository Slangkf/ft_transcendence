{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register --transpile-only src/index.ts",
    "dev": "ts-node -r tsconfig-paths/register --transpile-only src/index.ts",
    "dev:check": "cross-env NODE_ENV=development ts-node src/index.ts",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "build:prod": "npm run type-check && tsc",
    "db:migrate": "prisma db push --schema=./prisma/schema.prisma",
    "db:seed": "ts-node --project prisma/tsconfig.json prisma/seed.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --project prisma/tsconfig.json prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "fetch": "^1.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie": "^0.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  }
}
